# Dedicated test environment for Vitest and Prisma reset flows.
# This file is loaded explicitly by `vitest.config.mts` and by `scripts/test-db.sh`.

# Test Postgres (kept separate from normal dev DB)
POSTGRES_USER=blitz
POSTGRES_PASSWORD=devpass
POSTGRES_DB=manylanguagesplatform_test
POSTGRES_HOST_PORT=55432

DATABASE_URL="postgresql://blitz:devpass@localhost:55432/manylanguagesplatform_test"

# App secrets needed by Blitz / Next server code during tests
SESSION_SECRET_KEY=test-session-secret
CRON_SECRET=test-cron-secret
NODE_ENV=test
PORT=3001

# Safe dummy defaults for features that read these envs in test context
JATOS_BASE=http://jatos.test
NEXT_PUBLIC_JATOS_BASE=http://jatos.test
JATOS_TOKEN=test-token

EMAIL_ENABLED=false
EMAIL_PROVIDER=mailhog
EMAIL_FROM_ADDRESS="ManyLanguages Platform Test <noreply@example.com>"
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
POSTMARK_SERVER_TOKEN=
POSTMARK_MESSAGE_STREAM=outbound
