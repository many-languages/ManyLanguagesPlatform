# deploy/env/dev-fullstack.env.example
#
# Everything in Docker: app, databases, JATOS, Traefik.

# --- MySQL (JATOS) ---
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=jatos
MYSQL_USER=jatos
MYSQL_PASSWORD=devpass

# --- JATOS ---
JATOS_TOKEN=
JATOS_DOMAIN=jatos.localhost
JATOS_BASE=http://jatos.localhost
NEXT_PUBLIC_JATOS_BASE=http://jatos.localhost

# --- PostgreSQL (app) ---
POSTGRES_USER=blitz
POSTGRES_PASSWORD=devpass
POSTGRES_DB=manylanguagesplatform

# --- App ---
SESSION_SECRET_KEY=dev-secret-key-change-in-production
CRON_SECRET=dev-cron-secret
NODE_ENV=development
PORT=3000
APP_DOMAIN=app.localhost

# --- Email ---
EMAIL_ENABLED=true
EMAIL_PROVIDER=mailhog
EMAIL_FROM_ADDRESS="ManyLanguages Platform <noreply@example.com>"
SMTP_HOST=mailhog
SMTP_PORT=1025
