# deploy/env/dev-host-app.env.example
#
# Local development: app on host, infrastructure in Docker.
# Includes app Postgres + JATOS stack variables.

# --- MySQL (JATOS) ---
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=jatos
MYSQL_USER=jatos
MYSQL_PASSWORD=devpass

# --- JATOS ---
JATOS_TOKEN=
JATOS_DOMAIN=jatos.localhost
JATOS_BASE=http://jatos.localhost
NEXT_PUBLIC_JATOS_BASE=http://jatos.localhost

# --- PostgreSQL (app) ---
POSTGRES_USER=blitz
POSTGRES_PASSWORD=devpass
POSTGRES_DB=manylanguagesplatform
POSTGRES_HOST_PORT=5433

# --- App (host-side, not consumed by Compose but documented here) ---
# DATABASE_URL=postgresql://blitz:devpass@localhost:5433/manylanguagesplatform
# SESSION_SECRET_KEY=dev-secret-key
# CRON_SECRET=dev-cron-secret
