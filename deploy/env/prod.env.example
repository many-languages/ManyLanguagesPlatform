# deploy/env/prod.env.example
#
# Production environment. All CHANGE_ME values MUST be replaced.
# Do NOT commit the actual prod.env file.

# --- MySQL (JATOS) ---
MYSQL_ROOT_PASSWORD=CHANGE_ME
MYSQL_DATABASE=jatos
MYSQL_USER=jatos
MYSQL_PASSWORD=CHANGE_ME

# --- JATOS ---
JATOS_TOKEN=CHANGE_ME
JATOS_DOMAIN=jatos.your-domain.com

# --- PostgreSQL (app) ---
POSTGRES_USER=blitz
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=manylanguagesplatform

# --- App ---
SESSION_SECRET_KEY=CHANGE_ME
CRON_SECRET=CHANGE_ME
NODE_ENV=production
PORT=3000
APP_DOMAIN=app.your-domain.com
JATOS_BASE=https://jatos.your-domain.com
NEXT_PUBLIC_JATOS_BASE=https://jatos.your-domain.com

# --- Email ---
EMAIL_ENABLED=true
EMAIL_PROVIDER=postmark
EMAIL_FROM_ADDRESS="ManyLanguages Platform <noreply@your-domain.com>"
POSTMARK_SERVER_TOKEN=CHANGE_ME
POSTMARK_MESSAGE_STREAM=outbound

# --- TLS ---
TLS_EMAIL=admin@your-domain.com
