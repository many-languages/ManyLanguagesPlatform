# deploy/env/shared.env.example
#
# Variables used by multiple deployment modes.
# Copy to a local .env file and fill in values.

# --- MySQL (JATOS database) ---
MYSQL_ROOT_PASSWORD=CHANGE_ME_IN_PRODUCTION
MYSQL_DATABASE=jatos
MYSQL_USER=jatos
MYSQL_PASSWORD=CHANGE_ME_IN_PRODUCTION

# --- JATOS ---
JATOS_TOKEN=
JATOS_DOMAIN=jatos.localhost

# --- PostgreSQL (app database, not used by dev-jatos-only) ---
POSTGRES_USER=blitz
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_DB=manylanguagesplatform
POSTGRES_HOST_PORT=5433

# --- App ---
SESSION_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
CRON_SECRET=CHANGE_ME_IN_PRODUCTION
NODE_ENV=development
PORT=3000
APP_DOMAIN=app.localhost
JATOS_BASE=http://jatos.localhost
NEXT_PUBLIC_JATOS_BASE=http://jatos.localhost

# --- Email ---
EMAIL_ENABLED=false
EMAIL_PROVIDER=mailhog
EMAIL_FROM_ADDRESS="ManyLanguages Platform <noreply@example.com>"
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
POSTMARK_SERVER_TOKEN=
POSTMARK_MESSAGE_STREAM=outbound

# --- TLS (for Let's Encrypt / online HTTPS) ---
TLS_EMAIL=valid.email@you.com
